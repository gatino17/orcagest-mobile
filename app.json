{
  "expo": {
    "name": "orcagest-mobile",
    "slug": "orcagest-mobile",
    "scheme": "orcagest-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.orcagest.app",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "extra": {
      "router": {
        "origin": "https://app-router.dev"
      },
      "eas": {
        "projectId": "be7b3c9b-844c-4ce0-8665-0e8bd05a3a07"
      }
    },
    "plugins": [
      "expo-barcode-scanner"
    ]
  }
}
